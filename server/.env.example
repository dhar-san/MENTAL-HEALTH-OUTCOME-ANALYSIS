# Server Configuration
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/mental_health_analytics

# JWT Secret (change this in production!)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Comma-separated browser origins allowed to call this API (required for Vercel frontend + hosted backend)
# Example: https://your-app.vercel.app,https://www.yourdomain.com
CLIENT_ORIGINS=
